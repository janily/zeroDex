# Sepolia Position NFT discovery (optional)
#
# The frontend appends these query params to the URL below:
#   owner=<connected wallet>
#   contractAddress=<PositionManager address>
# The response must contain token IDs in one of the shapes supported by src/services/zan.ts:
#   { "result": { "data": [{ "tokenId": "1" }] } }
#   { "result": { "list": [{ "token_id": "1" }] } }
#   { "data": [{ "tokenID": "1" }] }
#
# Recommended: point this to your own same-origin/backend proxy that calls ZAN with
# a server-side API key. Example:
# VITE_ZAN_NFT_ENDPOINT=/api/zan/nfts-by-owner
VITE_ZAN_NFT_ENDPOINT=

# Optional for local/demo direct browser calls only. Vite exposes every VITE_* value
# in browser JavaScript, so do not put a production/private ZAN key here.
VITE_ZAN_API_KEY=
